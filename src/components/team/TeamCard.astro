---
import type { CollectionEntry } from 'astro:content';

interface Props {
  member: CollectionEntry<'team'>;
  compact?: boolean;
}

const { member, compact = false } = Astro.props;
const { name, role, photo, email, orcid, googleScholar, github, researchInterests } = member.data;
const slug = member.id;
---

<article class="bg-paper flex gap-4 p-5 group" style="border-bottom: none;">
  <!-- Photo -->
  <a href={`/team/${slug}`} class="flex-shrink-0" tabindex="-1" aria-hidden="true">
    <div class="w-14 h-14 overflow-hidden bg-gray-100" style="border: 1px solid var(--color-rule);">
      {photo ? (
        <img src={photo} alt={name} width="56" height="56"
             class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <div class="w-full h-full flex items-center justify-center font-sans text-lg font-semibold text-ink-faint select-none">
          {name.charAt(0)}
        </div>
      )}
    </div>
  </a>

  <!-- Info -->
  <div class="flex-1 min-w-0">
    <h3 class="font-sans font-semibold text-sm text-ink leading-tight">
      <a href={`/team/${slug}`} class="hover:text-accent transition-colors duration-150">{name}</a>
    </h3>
    <p class="text-xs text-ink-muted mt-0.5 font-sans">{role}</p>

    {!compact && researchInterests.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {researchInterests.slice(0, 3).map(interest => (
          <span class="tag">{interest}</span>
        ))}
      </div>
    )}

    <div class="mt-2 flex items-center gap-3">
      {email && (
        <a href={`mailto:${email}`} aria-label={`Email ${name}`}
           class="text-ink-faint hover:text-ink transition-colors text-xs">✉</a>
      )}
      {orcid && (
        <a href={`https://orcid.org/${orcid}`} aria-label="ORCID" target="_blank" rel="noopener"
           class="text-ink-faint hover:text-ink transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm-1.354 7.454H8.852V16.6h1.794V7.454zm-.897-2.877a1.132 1.132 0 100 2.264 1.132 1.132 0 000-2.264zm4.426 2.877h-1.794V16.6h1.794v-3.572c0-1.902 2.502-2.07 2.502 0V16.6h1.794v-4.277c0-3.394-3.84-3.271-4.296-1.599V7.454z"/>
          </svg>
        </a>
      )}
      {googleScholar && (
        <a href={googleScholar} aria-label="Google Scholar" target="_blank" rel="noopener"
           class="font-mono text-xs text-ink-faint hover:text-ink transition-colors tracking-tight">GS</a>
      )}
      {github && (
        <a href={github} aria-label="GitHub" target="_blank" rel="noopener"
           class="text-ink-faint hover:text-ink transition-colors">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>
