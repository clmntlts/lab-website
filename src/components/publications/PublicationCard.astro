---
import type { CollectionEntry } from 'astro:content';
import { getBibTeX, getCitation } from '../../lib/utils';

interface Props {
  pub: CollectionEntry<'publications'>;
  view?: 'card' | 'list';
  highlightAuthor?: string;
}

const { pub, view = 'card', highlightAuthor } = Astro.props;
const { title, authors, year, venue, venueShort, type, doi, arxiv, pdf, code, abstract, keywords, categories, featured, award } = pub.data;

const bibtexKey = pub.id.replace(/\.(yaml|json)$/, '');
const bibtex = getBibTeX(pub.data, bibtexKey);
const citation = getCitation(pub.data);

const doiUrl = doi ? `https://doi.org/${doi}` : null;
const arxivUrl = arxiv ? `https://arxiv.org/abs/${arxiv}` : null;

---

<article
  class:list={['pub-card group', view === 'card' ? 'card p-5' : 'py-5']}
  data-pub-id={pub.id} data-year={year} data-type={type}
  data-categories={categories.join(',')}
  data-title={title.toLowerCase()} data-authors={authors.join(' ').toLowerCase()}
>
  <div class="flex flex-col gap-2.5">
    <!-- Title + type label -->
    <div class="flex items-start justify-between gap-4">
      <h3 class="font-sans text-sm font-semibold text-ink leading-snug group-hover:text-accent transition-colors duration-150">
        {doiUrl ? (
          <a href={doiUrl} target="_blank" rel="noopener">{title}</a>
        ) : arxivUrl ? (
          <a href={arxivUrl} target="_blank" rel="noopener">{title}</a>
        ) : (
          <a href={`/publications/${pub.id}`}>{title}</a>
        )}
      </h3>
      <div class="flex flex-shrink-0 items-center gap-2 mt-0.5">
        <span class="eyebrow">{type}</span>
        {award && <span class="eyebrow text-amber-600">â˜… {award}</span>}
      </div>
    </div>

    <!-- Authors & venue -->
    <div class="text-sm text-ink-muted space-y-0.5">
      <p>
        {authors.map((a, i) => {
          const isHighlighted = highlightAuthor && a === highlightAuthor;
          return (
            <>
              {i > 0 && ', '}
              {isHighlighted ? <strong class="text-ink">{a}</strong> : a}
            </>
          );
        })}
      </p>
      <p class="font-medium">
        <span class="italic">{venueShort ?? venue}</span>
        <span class="mx-1">Â·</span>
        <span>{year}</span>
      </p>
    </div>

    <!-- Abstract (collapsible) -->
    {abstract && (
      <details class="group/abstract">
        <summary class="cursor-pointer text-xs text-accent hover:text-accent-dark select-none list-none flex items-center gap-1">
          <svg class="w-3 h-3 transition-transform group-open/abstract:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
          Abstract
        </summary>
        <p class="mt-2 text-sm text-ink-muted leading-relaxed font-serif">{abstract}</p>
      </details>
    )}

    <!-- Keywords -->
    {keywords.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {keywords.map(kw => (
          <span class="tag text-xs">{kw}</span>
        ))}
      </div>
    )}

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-2 pt-1">
      {doiUrl && (
        <a href={doiUrl} target="_blank" rel="noopener" class="btn-ghost text-xs py-1 px-2.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          DOI
        </a>
      )}
      {arxivUrl && (
        <a href={arxivUrl} target="_blank" rel="noopener" class="btn-ghost text-xs py-1 px-2.5">arXiv</a>
      )}
      {pdf && (
        <a href={pdf} target="_blank" rel="noopener" class="btn-ghost text-xs py-1 px-2.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          PDF
        </a>
      )}
      {pdf && (
        <a href={pdf} download class="btn-ghost text-xs py-1 px-2.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Download
        </a>
      )}
      {code && (
        <a href={code} target="_blank" rel="noopener" class="btn-ghost text-xs py-1 px-2.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          Code
        </a>
      )}

      <!-- Copy citation -->
      <button
        class="btn-ghost text-xs py-1 px-2.5 copy-cite-btn"
        data-citation={citation}
        aria-label="Copy citation"
        title="Copy citation"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
        </svg>
        <span class="copy-cite-label">Cite</span>
      </button>

      <!-- Copy BibTeX -->
      <button
        class="btn-ghost text-xs py-1 px-2.5 copy-bibtex-btn"
        data-bibtex={bibtex}
        aria-label="Copy BibTeX"
      >
        BibTeX
      </button>
    </div>
  </div>
</article>

<script>
  document.querySelectorAll('.copy-cite-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const citation = btn.getAttribute('data-citation') ?? '';
      await navigator.clipboard.writeText(citation);
      const label = btn.querySelector('.copy-cite-label');
      if (label) {
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Cite'; }, 2000);
      }
    });
  });

  document.querySelectorAll('.copy-bibtex-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const bibtex = btn.getAttribute('data-bibtex') ?? '';
      await navigator.clipboard.writeText(bibtex);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });
</script>
