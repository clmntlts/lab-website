---
import { SITE } from '../../lib/config';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-paper/95 backdrop-blur-sm"
        style="border-bottom: 1px solid var(--color-rule);">
  <div class="container-lab">
    <nav aria-label="Main navigation" class="flex items-center justify-between h-14">

      <!-- Wordmark -->
      <a href="/" class="flex items-center gap-3 group" aria-label={`${SITE.name} — Home`}>
        <span class="font-sans text-xs font-bold tracking-widest uppercase text-ink"
              style="letter-spacing: 0.15em;">
          {SITE.shortName ?? 'NCL'}
        </span>
        <span class="hidden sm:block text-rule" style="color: var(--color-rule);" aria-hidden="true">|</span>
        <span class="hidden sm:block font-sans text-xs text-ink-muted truncate max-w-xs">
          {SITE.department}
        </span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-0" role="list">
        {SITE.nav.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class="block px-3.5 py-1 text-xs font-medium transition-colors duration-150"
                style={isActive
                  ? 'color: var(--color-accent);'
                  : 'color: var(--color-ink-muted);'}
                onmouseover="if(!this.getAttribute('aria-current')) this.style.color='var(--color-ink)'"
                onmouseout="if(!this.getAttribute('aria-current')) this.style.color='var(--color-ink-muted)'"
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Controls -->
      <div class="flex items-center gap-1">
        <a href="/search" aria-label="Search"
           class="p-2 text-ink-faint hover:text-ink transition-colors duration-150">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
          </svg>
        </a>

        <button id="theme-toggle" aria-label="Toggle dark mode"
                class="p-2 text-ink-faint hover:text-ink transition-colors duration-150">
          <svg id="icon-sun" class="w-3.5 h-3.5 hidden dark:block" fill="none"
               stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg id="icon-moon" class="w-3.5 h-3.5 dark:hidden" fill="none"
               stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>

        <button id="mobile-menu-btn" aria-label="Menu" aria-expanded="false"
                aria-controls="mobile-menu"
                class="md:hidden p-2 text-ink-faint hover:text-ink transition-colors duration-150">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2"
               viewBox="0 0 24 24" aria-hidden="true">
            <path id="menu-icon-open"  stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
            <path id="menu-icon-close" stroke-linecap="round" d="M6 18L18 6M6 6l12 12" class="hidden"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-paper"
       style="border-top: 1px solid var(--color-rule);">
    <ul class="container-lab py-2" role="list">
      {SITE.nav.map((item) => {
        const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <li>
            <a href={item.href} aria-current={isActive ? 'page' : undefined}
               class="block py-2.5 text-sm font-medium transition-colors"
               style={isActive ? 'color: var(--color-accent);' : 'color: var(--color-ink-muted);'}>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  const btn      = document.getElementById('mobile-menu-btn');
  const menu     = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
