---
import { SITE } from '../../lib/config';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-paper/95 dark:bg-ink/95 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800">
  <div class="container-lab">
    <nav aria-label="Main navigation" class="flex items-center justify-between h-16">
      <!-- Logo / Lab name -->
      <a href="/" class="flex items-center gap-3 group" aria-label={`${SITE.name} — Home`}>
        <div class="flex flex-col leading-none" aria-hidden="true">
          <span class="font-sans text-sm font-semibold text-accent tracking-widest uppercase">NCL</span>
          <div class="h-0.5 w-0 bg-margin group-hover:w-full transition-all duration-300"></div>
        </div>
        <div class="hidden sm:block">
          <div class="font-sans text-sm font-semibold text-ink dark:text-white leading-tight">
            Neural Computation<br class="hidden lg:block" /> Laboratory
          </div>
        </div>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {SITE.nav.map((item) => {
          const isActive = currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'px-3 py-1.5 text-sm font-medium rounded transition-colors',
                  isActive
                    ? 'text-accent bg-accent-muted dark:bg-blue-900/30'
                    : 'text-ink-muted dark:text-gray-400 hover:text-ink dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800'
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Right controls -->
      <div class="flex items-center gap-2">
        <!-- Search -->
        <a
          href="/search"
          aria-label="Search site"
          class="p-2 rounded-md text-ink-muted hover:text-ink dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
          </svg>
        </a>
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Toggle dark mode"
          class="p-2 rounded-md text-ink-muted hover:text-ink dark:text-gray-400 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg id="icon-moon" class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          aria-label="Open mobile menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden p-2 rounded-md text-ink-muted hover:text-ink hover:bg-gray-100 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 dark:border-gray-800 bg-paper dark:bg-ink">
    <ul class="container-lab py-3 space-y-1" role="list">
      {SITE.nav.map((item) => {
        const isActive = currentPath.startsWith(item.href);
        return (
          <li>
            <a
              href={item.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'block px-3 py-2 text-sm font-medium rounded',
                isActive
                  ? 'text-accent bg-accent-muted'
                  : 'text-ink-muted hover:text-ink hover:bg-gray-100 dark:text-gray-400 dark:hover:text-white dark:hover:bg-gray-800'
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  // Dark mode toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
