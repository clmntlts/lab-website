---
import { SITE } from '../../lib/config';

const currentYear = new Date().getFullYear();
---

<footer class="mt-20" style="border-top: 1px solid var(--color-rule);">
  <div class="container-lab py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

      <!-- Lab info -->
      <div>
        <p class="font-sans text-xs font-bold tracking-widest uppercase text-ink mb-1"
           style="letter-spacing: 0.15em;">{SITE.shortName ?? 'NCL'}</p>
        <p class="font-sans text-sm text-ink-muted mb-4 leading-relaxed">{SITE.description}</p>
        <address class="text-xs text-ink-faint not-italic space-y-0.5 leading-relaxed">
          <p>{SITE.department}</p>
          <p>{SITE.institution}</p>
          <p>{SITE.address}</p>
          <p class="mt-2">
            <a href={`mailto:${SITE.email}`}
               class="text-ink-muted hover:text-ink transition-colors">{SITE.email}</a>
          </p>
        </address>
      </div>

      <!-- Navigation -->
      <div>
        <p class="eyebrow mb-3">Navigate</p>
        <ul class="space-y-2" role="list">
          {SITE.nav.map(item => (
            <li>
              <a href={item.href}
                 class="text-sm text-ink-muted hover:text-ink transition-colors duration-150">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <p class="eyebrow mb-3">Connect</p>
        <div class="flex gap-4 mb-4">
          <a href={SITE.github} aria-label="GitHub"
             class="text-ink-faint hover:text-ink transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
          <a href={`https://twitter.com/${SITE.twitter?.replace('@','')}`} aria-label="X / Twitter"
             class="text-ink-faint hover:text-ink transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a href="/rss.xml" aria-label="RSS Feed"
             class="text-ink-faint hover:text-ink transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
            </svg>
          </a>
        </div>
        <a href="/contact" class="text-sm text-ink-muted hover:text-ink transition-colors">
          Open positions &rarr;
        </a>
      </div>
    </div>

    <div class="pt-6 flex flex-col sm:flex-row justify-between gap-2 text-xs text-ink-faint"
         style="border-top: 1px solid var(--color-rule);">
      <p>© {currentYear} {SITE.name}. Licensed under <a href="https://creativecommons.org/licenses/by/4.0/" class="hover:text-ink-muted transition-colors">CC BY 4.0</a>.</p>
      <p>Built with <a href="https://astro.build" class="hover:text-ink-muted transition-colors">Astro</a>.</p>
    </div>
  </div>
</footer>
