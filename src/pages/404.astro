---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noIndex>
  <div class="container-lab py-24 text-center">
    <div class="font-mono text-8xl font-bold text-accent/20 mb-4" aria-hidden="true">404</div>
    <h1 class="font-sans text-3xl font-semibold text-ink dark:text-white mb-4">Page not found</h1>
    <p class="font-serif text-lg text-ink-muted dark:text-gray-400 mb-8 max-w-md mx-auto">
      The page you are looking for may have moved or doesn't exist.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Go to Home</a>
      <a href="/publications" class="btn-ghost">Browse Publications</a>
      <a href="/team" class="btn-ghost">Meet the Team</a>
    </div>
  </div>
</BaseLayout>
