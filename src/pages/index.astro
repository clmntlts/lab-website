---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PublicationCard from '../components/publications/PublicationCard.astro';
import TeamCard from '../components/team/TeamCard.astro';
import { SITE } from '../lib/config';
import { sortByYear } from '../lib/utils';

const allPubs = await getCollection('publications');
const featuredPubs = sortByYear(allPubs).filter(p => p.data.featured).slice(0, 3);

const allTeam = await getCollection('team');
const sortedTeam = allTeam.sort((a, b) => a.data.order - b.data.order);


const researchTopics = [
  {
    label: '01',
    title: 'Reading & Spelling Development',
    desc: 'How children acquire written language skills, and what cognitive and linguistic factors drive progress.',
  },
  {
    label: '02',
    title: 'Literacy Prerequisites',
    desc: 'The role of metaphonological awareness and rapid automatized naming in predicting reading outcomes.',
  },
  {
    label: '03',
    title: 'Handwriting & Graphomotor Skills',
    desc: 'Development of the handwriting gesture, its connection to orthographic learning, and motor dysfunctions in dyslexia.',
  },
  {
    label: '04',
    title: 'Intervention & Clinical Applications',
    desc: 'Evidence-based interventions for dyslexia and dysorthography, with tools for speech-language pathologists and teachers.',
  },
];
---

<BaseLayout
  description="DeLi Lab studies the acquisition and disorders of written language at UCLouvain — reading, spelling, and handwriting research with clinical and educational applications."
>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="container-lab pt-20 pb-16 md:pt-28 md:pb-20" aria-label="Lab introduction">
    <div class="flex gap-8 md:gap-10">
      <!-- The red margin — French école signature, used only here -->
      <div style="flex-shrink: 0; display: flex; flex-direction: column;">
        <div style="width: 2px; flex: 1; margin-top: 0.5rem; background-color: var(--color-margin);"></div>
      </div>
      <div>
    <p class="eyebrow mb-5">{SITE.institution} &nbsp;·&nbsp; {SITE.department}</p>
    <h1 style="font-family: var(--font-family-serif); font-size: clamp(2.25rem, 5.5vw, 4rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.1; color: var(--color-ink); margin-bottom: 1.5rem;">
      Development<br />of Literacy<br />
      <em style="font-style: italic; color: var(--color-accent);">Laboratory</em>
    </h1>
    <p class="font-serif leading-relaxed max-w-xl mb-10"
       style="font-size: 1.0625rem; color: var(--color-ink-muted); font-style: italic;">
      We study how children acquire written language — reading, spelling, and handwriting —
      and what goes wrong in developmental disorders such as dyslexia and dysorthography.
      Our work bridges cognitive psychology, neuroscience, and educational practice.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/research" class="btn-primary">Our Research &rarr;</a>
      <a href="/publications" class="btn-ghost">Publications</a>
      <a href="/contact" class="btn-accent">Participate</a>
    </div>
      </div>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Typographic interstitial ─────────────────────────
       Visual cue to the subject: the act of learning to write.
       No imagery — the sentence itself is the design.
  ─────────────────────────────────────────────────────────── -->
  <section aria-label="Lab philosophy" style="overflow: hidden; position: relative;">
    <div class="container-lab" style="padding-top: 4rem; padding-bottom: 4rem;">
      <!-- Faint background letterform — the letter 'a', the first thing a child learns -->
      <span aria-hidden="true" style="
        position: absolute;
        right: -0.5rem;
        top: 50%;
        transform: translateY(-54%);
        font-family: var(--font-family-serif);
        font-size: clamp(12rem, 30vw, 22rem);
        font-weight: 600;
        line-height: 1;
        color: var(--color-rule);
        user-select: none;
        pointer-events: none;
        letter-spacing: -0.05em;
      ">a</span>

      <!-- The sentence -->
      <blockquote style="
        position: relative;
        max-width: 36ch;
        margin: 0;
        padding: 0;
        border: none;
      ">
        <p style="
          font-family: var(--font-family-serif);
          font-style: italic;
          font-size: clamp(1.375rem, 3vw, 1.875rem);
          line-height: 1.45;
          color: var(--color-ink);
          letter-spacing: -0.01em;
        ">
          Before a child can write, they must learn
          that marks on a page carry meaning.
          We study every step of that journey.
        </p>
      </blockquote>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Research Themes ───────────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="themes-heading">
    <header class="mb-10">
      <p class="eyebrow mb-2">Focus areas</p>
      <h2 id="themes-heading" class="section-heading">Research Themes</h2>
      <p class="section-lead">
        Four interconnected questions about how children learn to read and write —
        and what can be done when the process goes awry.
      </p>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px" style="background-color: var(--color-rule);">
      {researchTopics.map((topic) => (
        <div class="p-6 group" style="background-color: var(--color-paper);">
          <span class="font-mono text-xs text-ink-faint mb-4 block">{topic.label}</span>
          <h3 class="font-sans font-semibold text-sm text-ink mb-2
                     group-hover:text-accent transition-colors duration-150">
            {topic.title}
          </h3>
          <p class="font-serif text-sm text-ink-muted leading-relaxed">{topic.desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-5 text-right">
      <a href="/research" class="link text-sm">All research &rarr;</a>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Selected Publications ─────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="pubs-heading">
    <header class="mb-8">
      <p class="eyebrow mb-2">Recent work</p>
      <h2 id="pubs-heading" class="section-heading">Selected Publications</h2>
    </header>
    <div style="border-top: 1px solid var(--color-rule); border-bottom: 1px solid var(--color-rule);">
      {featuredPubs.length > 0
        ? featuredPubs.map(pub => <PublicationCard pub={pub} view="list" />)
        : (
          <p class="py-8 text-sm text-ink-muted font-serif italic">
            Publications are being updated — see the full list below.
          </p>
        )
      }
    </div>
    <div class="mt-6 text-right">
      <a href="/publications" class="link text-sm">All publications &rarr;</a>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Team ──────────────────────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="team-heading">
    <header class="mb-8">
      <p class="eyebrow mb-2">People</p>
      <h2 id="team-heading" class="section-heading">The Team</h2>
      <p class="section-lead">
        Speech-language pathologists, psychologists, and educators united by a shared
        interest in how written language develops and can be supported.
      </p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px" style="background-color: var(--color-rule);">
      {sortedTeam.slice(0, 4).map(member => (
        <TeamCard member={member} compact />
      ))}
    </div>
    <div class="mt-6 text-right">
      <a href="/team" class="link text-sm">Full team &rarr;</a>
    </div>
  </section>


  <!-- ── Participate CTA ───────────────────────────────── -->
  <section style="border-top: 1px solid var(--color-rule); border-bottom: 1px solid var(--color-rule);">
    <div class="container-lab py-14">
      <div class="max-w-xl">
        <p class="eyebrow mb-3">Participate in research</p>
        <h2 class="section-heading mb-3">Support literacy science</h2>
        <p class="section-lead" style="margin-bottom: 1.5rem;">
          We regularly recruit children and adults for studies on reading, spelling,
          and handwriting. Participation is free, voluntary, and takes place at UCLouvain.
        </p>
        <a href="/contact" class="btn-primary">Get in touch &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
