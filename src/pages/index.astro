---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PublicationCard from '../components/publications/PublicationCard.astro';
import TeamCard from '../components/team/TeamCard.astro';
import { SITE } from '../lib/config';
import { sortByYear } from '../lib/utils';

const allPubs = await getCollection('publications');
const featuredPubs = sortByYear(allPubs).filter(p => p.data.featured).slice(0, 3);

const allTeam = await getCollection('team');
const sortedTeam = allTeam.sort((a, b) => a.data.order - b.data.order);

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .filter(n => n.data.featured)
  .slice(0, 3);

const researchTopics = [
  { label: '01', title: 'Neural Geometry', desc: 'How the shape of population activity constrains neural computation.' },
  { label: '02', title: 'Predictive Coding', desc: 'Normative theories of hierarchical inference in cortical circuits.' },
  { label: '03', title: 'Working Memory', desc: 'Dynamical mechanisms of persistent activity in prefrontal cortex.' },
  { label: '04', title: 'Generative Models', desc: 'Deep latent variable models for neural population dynamics.' },
];
---

<BaseLayout>

  <!-- ── Hero ─────────────────────────────────────────── -->
  <section class="container-lab pt-20 pb-16 md:pt-28 md:pb-20" aria-label="Lab introduction">
    <p class="eyebrow mb-6">{SITE.institution} &nbsp;·&nbsp; {SITE.department}</p>
    <h1 class="font-sans font-semibold tracking-tight leading-none text-ink mb-8"
        style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
      Neural<br />Computation<br />
      <span class="text-accent">Laboratory</span>
    </h1>
    <p class="font-serif text-lg text-ink-muted leading-relaxed max-w-xl mb-10">
      We investigate how neural circuits represent, transform, and communicate
      information — bridging mathematics, machine learning, and experimental
      neuroscience.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/research" class="btn-primary">Research &rarr;</a>
      <a href="/publications" class="btn-ghost">Publications</a>
      <a href="/contact" class="btn-accent">Join the Lab</a>
    </div>
  </section>

  <hr class="container-lab" style="margin-left: auto; margin-right: auto; max-width: 72rem; padding: 0 4rem;" />
  <div style="border-top: 1px solid var(--color-rule); margin: 0 0;"></div>

  <!-- ── Stats ─────────────────────────────────────────── -->
  <section class="container-lab py-10" aria-label="Lab statistics">
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-px bg-rule" style="background-color: var(--color-rule);">
      {[
        { value: '5',   label: 'Team members' },
        { value: '20+', label: 'Publications' },
        { value: '2',   label: 'Active grants' },
        { value: String(new Date().getFullYear() - SITE.founded), label: 'Years active' },
      ].map(stat => (
        <div class="bg-paper px-6 py-5">
          <dt class="font-sans text-2xl font-semibold text-ink tracking-tight"
              style="font-variant-numeric: tabular-nums;">{stat.value}</dt>
          <dd class="mt-0.5 text-xs text-ink-faint font-sans uppercase tracking-widest"
              style="letter-spacing: 0.08em;">{stat.label}</dd>
        </div>
      ))}
    </dl>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Research Themes ───────────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="themes-heading">
    <header class="mb-10">
      <p class="eyebrow mb-2">Focus areas</p>
      <h2 id="themes-heading" class="section-heading">Research Themes</h2>
      <p class="section-lead">Four interconnected questions about computation in biological and artificial neural networks.</p>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-px" style="background-color: var(--color-rule);">
      {researchTopics.map((topic) => (
        <div class="bg-paper p-6 group">
          <span class="font-mono text-xs text-ink-faint mb-4 block">{topic.label}</span>
          <h3 class="font-sans font-semibold text-ink text-base mb-2 group-hover:text-accent transition-colors duration-150">
            {topic.title}
          </h3>
          <p class="text-sm text-ink-muted font-serif leading-relaxed">{topic.desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-5 text-right">
      <a href="/research" class="link text-sm">All research &rarr;</a>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Selected Publications ─────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="pubs-heading">
    <header class="mb-8">
      <p class="eyebrow mb-2">Recent work</p>
      <h2 id="pubs-heading" class="section-heading">Selected Publications</h2>
    </header>
    <div class="divide-y" style="border-top: 1px solid var(--color-rule); border-bottom: 1px solid var(--color-rule);">
      {featuredPubs.map(pub => (
        <PublicationCard pub={pub} view="list" />
      ))}
    </div>
    <div class="mt-6 text-right">
      <a href="/publications" class="link text-sm">All publications &rarr;</a>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── Team ──────────────────────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="team-heading">
    <header class="mb-8">
      <p class="eyebrow mb-2">People</p>
      <h2 id="team-heading" class="section-heading">The Team</h2>
      <p class="section-lead">Researchers from diverse backgrounds united by curiosity about the brain.</p>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px" style="background-color: var(--color-rule);">
      {sortedTeam.slice(0, 4).map(member => (
        <TeamCard member={member} compact />
      ))}
    </div>
    <div class="mt-6 text-right">
      <a href="/team" class="link text-sm">Full team &rarr;</a>
    </div>
  </section>

  <div style="border-top: 1px solid var(--color-rule);"></div>

  <!-- ── News ──────────────────────────────────────────── -->
  <section class="container-lab py-16" aria-labelledby="news-heading">
    <header class="mb-8">
      <p class="eyebrow mb-2">Updates</p>
      <h2 id="news-heading" class="section-heading">Latest News</h2>
    </header>
    <div style="border-top: 1px solid var(--color-rule);">
      {recentNews.map(item => (
        <article class="py-5 flex gap-6" style="border-bottom: 1px solid var(--color-rule);">
          <time class="flex-shrink-0 font-mono text-xs text-ink-faint pt-0.5 w-24 leading-relaxed"
                datetime={item.data.date.toISOString()}>
            {item.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
          </time>
          <div>
            <span class="eyebrow mb-1 block">{item.data.category}</span>
            <h3 class="font-sans font-semibold text-ink text-sm leading-snug mb-1">
              <a href={`/news/${item.id}`} class="hover:text-accent transition-colors duration-150">
                {item.data.title}
              </a>
            </h3>
            <p class="text-sm text-ink-muted font-serif leading-relaxed">{item.data.summary}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="mt-6 text-right">
      <a href="/news" class="link text-sm">All news &rarr;</a>
    </div>
  </section>

</BaseLayout>
