---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('news');
  return items.map(item => ({ params: { slug: item.id }, props: { item } }));
}

interface Props { item: CollectionEntry<'news'>; }
const { item } = Astro.props;
const { Content } = await render(item);

const categoryColors: Record<string, string> = {
  Award: 'bg-yellow-50 text-yellow-700',
  Publication: 'bg-green-50 text-green-700',
  Grant: 'bg-purple-50 text-purple-700',
  Event: 'bg-blue-50 text-blue-700',
  Hiring: 'bg-accent-muted text-accent-dark',
  Media: 'bg-pink-50 text-pink-700',
  General: 'bg-gray-50 text-gray-700',
};
---

<BaseLayout title={item.data.title} description={item.data.summary}>
  <div class="container-lab py-12 max-w-3xl">
    <nav aria-label="Breadcrumb" class="mb-8">
      <a href="/news" class="text-sm text-ink-faint hover:text-accent transition-colors flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        All news
      </a>
    </nav>

    <article>
      <header class="mb-8">
        <span class:list={['inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium mb-4', categoryColors[item.data.category] ?? categoryColors.General]}>
          {item.data.category}
        </span>
        <h1 class="font-sans text-3xl font-semibold text-ink dark:text-white leading-snug mb-3">
          {item.data.title}
        </h1>
        <time class="text-sm text-ink-faint" datetime={item.data.date.toISOString()}>
          {item.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
      </header>

      <div class="prose prose-base dark:prose-invert max-w-none font-serif">
        <Content />
      </div>

      {item.data.externalUrl && (
        <div class="mt-8 pt-6 border-t border-gray-100 dark:border-gray-800">
          <a href={item.data.externalUrl} target="_blank" rel="noopener" class="btn-primary">
            Read full story &rarr;
          </a>
        </div>
      )}
    </article>
  </div>
</BaseLayout>
