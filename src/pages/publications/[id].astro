---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getBibTeX, getCitation } from '../../lib/utils';

export async function getStaticPaths() {
  const pubs = await getCollection('publications');
  return pubs.map(pub => ({ params: { id: pub.id }, props: { pub } }));
}

interface Props { pub: CollectionEntry<'publications'>; }
const { pub } = Astro.props;
const {
  title, authors, year, venue, venueShort, type, doi, arxiv, pdf,
  code, abstract, keywords, categories, award, image,
} = pub.data;

const doiUrl = doi ? `https://doi.org/${doi}` : null;
const arxivUrl = arxiv ? `https://arxiv.org/abs/${arxiv}` : null;
const bibtex = getBibTeX(pub.data, pub.id);
const citation = getCitation(pub.data);

const typeLabels: Record<string, string> = {
  journal: 'Journal Article',
  conference: 'Conference Paper',
  preprint: 'Preprint',
  'book-chapter': 'Book Chapter',
  thesis: 'Thesis',
  workshop: 'Workshop Paper',
};

// Structured data for Google Scholar / search engines
const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  'headline': title,
  'author': authors.map(a => ({ '@type': 'Person', 'name': a })),
  'datePublished': String(year),
  'isPartOf': { '@type': 'Periodical', 'name': venue },
  ...(doi ? { 'identifier': { '@type': 'PropertyValue', 'propertyID': 'doi', 'value': doi } } : {}),
  ...(abstract ? { 'abstract': abstract } : {}),
};
---

<BaseLayout
  title={title}
  description={abstract ? abstract.slice(0, 155) + '…' : `${title} — ${venue}, ${year}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} slot="head" />

  <div class="container-lab py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <a href="/publications" class="text-sm text-ink-faint hover:text-accent transition-colors flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        All publications
      </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Main -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Header -->
        <header>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-accent-muted text-accent-dark">
              {typeLabels[type] ?? type}
            </span>
            {award && (
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded text-xs font-medium bg-yellow-50 text-yellow-700">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                {award}
              </span>
            )}
          </div>

          <h1 class="font-sans text-2xl md:text-3xl font-semibold text-ink dark:text-white leading-snug mb-4">
            {title}
          </h1>

          <div class="space-y-1 text-sm text-ink-muted dark:text-gray-400">
            <p class="font-serif">
              {authors.map((a, i) => (
                <>{i > 0 && ', '}{a}</>
              ))}
            </p>
            <p>
              <span class="font-medium italic">{venue}</span>
              <span class="mx-2">&middot;</span>
              <span>{year}</span>
            </p>
          </div>
        </header>

        <!-- Abstract -->
        {abstract && (
          <section aria-labelledby="abstract-heading">
            <h2 id="abstract-heading" class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Abstract</h2>
            <p class="font-serif text-base leading-relaxed text-ink dark:text-gray-200">{abstract}</p>
          </section>
        )}

        <!-- Keywords -->
        {keywords.length > 0 && (
          <section aria-labelledby="keywords-heading">
            <h2 id="keywords-heading" class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Keywords</h2>
            <div class="flex flex-wrap gap-2">
              {keywords.map(k => <span class="tag">{k}</span>)}
            </div>
          </section>
        )}

        <!-- Categories -->
        {categories.length > 0 && (
          <section aria-labelledby="categories-heading">
            <h2 id="categories-heading" class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Categories</h2>
            <div class="flex flex-wrap gap-2">
              {categories.map(c => (
                <a href={`/publications?category=${encodeURIComponent(c)}`} class="tag hover:bg-accent hover:text-white transition-colors">{c}</a>
              ))}
            </div>
          </section>
        )}

        <!-- PDF Preview -->
        {pdf && (
          <section aria-labelledby="pdf-heading">
            <h2 id="pdf-heading" class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">PDF Preview</h2>
            <div class="rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
              <iframe
                src={`${pdf}#toolbar=1&navpanes=0&scrollbar=1`}
                class="w-full h-[600px]"
                title={`PDF preview of: ${title}`}
                loading="lazy"
              ></iframe>
            </div>
            <div class="mt-2 flex gap-3">
              <a href={pdf} target="_blank" rel="noopener" class="link text-sm">Open in new tab</a>
              <a href={pdf} download class="link text-sm">Download PDF</a>
            </div>
          </section>
        )}

        <!-- Citation formats -->
        <section aria-labelledby="cite-heading">
          <h2 id="cite-heading" class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Cite</h2>
          <div class="space-y-3">
            <!-- Plain text -->
            <div>
              <p class="text-xs text-ink-faint mb-1">Plain text</p>
              <div class="relative">
                <pre class="font-mono text-xs bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md p-4 whitespace-pre-wrap overflow-x-auto">{citation}</pre>
                <button
                  class="copy-btn absolute top-2 right-2 px-2 py-1 text-xs font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded hover:bg-gray-50 transition-colors"
                  data-text={citation}
                  aria-label="Copy plain text citation"
                >Copy</button>
              </div>
            </div>
            <!-- BibTeX -->
            <div>
              <p class="text-xs text-ink-faint mb-1">BibTeX</p>
              <div class="relative">
                <pre class="font-mono text-xs bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-md p-4 whitespace-pre-wrap overflow-x-auto">{bibtex}</pre>
                <button
                  class="copy-btn absolute top-2 right-2 px-2 py-1 text-xs font-medium bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded hover:bg-gray-50 transition-colors"
                  data-text={bibtex}
                  aria-label="Copy BibTeX"
                >Copy</button>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="card p-5 space-y-5">
          <!-- Quick links -->
          <div>
            <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Links</h2>
            <ul class="space-y-2" role="list">
              {doiUrl && (
                <li>
                  <a href={doiUrl} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-accent transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Publisher (DOI)
                  </a>
                </li>
              )}
              {arxivUrl && (
                <li>
                  <a href={arxivUrl} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-accent transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    arXiv preprint
                  </a>
                </li>
              )}
              {pdf && (
                <li>
                  <a href={pdf} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-accent transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    View PDF
                  </a>
                </li>
              )}
              {pdf && (
                <li>
                  <a href={pdf} download class="flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-accent transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                    Download PDF
                  </a>
                </li>
              )}
              {code && (
                <li>
                  <a href={code} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-accent transition-colors">
                    <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                    Source code
                  </a>
                </li>
              )}
            </ul>
          </div>

          <!-- Details -->
          <div class="pt-4 border-t border-gray-100 dark:border-gray-800 space-y-3 text-sm">
            <div>
              <p class="text-xs text-ink-faint mb-0.5">Year</p>
              <p class="font-medium">{year}</p>
            </div>
            <div>
              <p class="text-xs text-ink-faint mb-0.5">Venue</p>
              <p class="font-medium">{venue}</p>
            </div>
            <div>
              <p class="text-xs text-ink-faint mb-0.5">Type</p>
              <p class="font-medium">{typeLabels[type]}</p>
            </div>
            {doi && (
              <div>
                <p class="text-xs text-ink-faint mb-0.5">DOI</p>
                <p class="font-mono text-xs break-all">{doi}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Share -->
        <div class="card p-5">
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Share</h2>
          <div class="flex gap-2">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://compneuro-lab.university.edu/publications/${pub.id}`)}`}
              target="_blank"
              rel="noopener"
              class="btn-ghost text-xs py-1 px-2.5"
            >
              Share on X
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-text') ?? '';
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
