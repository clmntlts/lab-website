---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/config';

const milestones = [
  { year: 2018, event: 'Lab founded at the University of Somewhere. First two PhD students recruited.' },
  { year: 2019, event: 'CNRS Bronze Medal awarded to Prof. Vasquez. First paper published in Nature Neuroscience.' },
  { year: 2020, event: 'Sophie Mercier joins as Research Engineer. NeuroKit toolkit released open source.' },
  { year: 2021, event: 'ANR grant awarded for Predictive Coding project. Aisha Okonkwo joins as PhD student.' },
  { year: 2022, event: 'Lab moves to new building with expanded recording facilities. Kaito Nakamura joins as postdoc.' },
  { year: 2023, event: 'ERC Starting Grant (€1.5M) awarded. Thomas Brun joins as PhD student. NeurIPS spotlight paper.' },
  { year: 2024, event: 'Riemannian geometry paper published in Nature Neuroscience (Editor\'s Choice). New positions open.' },
];

const values = [
  { title: 'Scientific rigor', body: 'We hold ourselves to the highest standards of experimental and theoretical practice.' },
  { title: 'Openness', body: 'All code, data, and preprints are freely available. Science thrives in the open.' },
  { title: 'Mentorship', body: 'Every lab member receives dedicated mentorship and career support, regardless of career stage.' },
  { title: 'Inclusion', body: 'We actively recruit researchers from under-represented groups and foster a welcoming environment.' },
];
---

<BaseLayout title="About" description={`About the ${SITE.name} — mission, values, and history.`}>
  <div class="container-lab py-12">
    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <h1 class="section-heading">About the Lab</h1>
      <p class="font-serif text-lg leading-relaxed text-ink dark:text-gray-200">
        The Neural Computation Laboratory investigates how neural circuits represent, transform,
        and communicate information. We combine mathematical theory, large-scale neural recordings,
        and computational modeling to understand the principles of neural computation.
      </p>
    </div>

    <!-- Mission & approach -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 mb-16 pb-16 border-b border-gray-200 dark:border-gray-800">
      <div>
        <h2 class="font-sans text-xl font-semibold text-ink dark:text-white mb-4">Mission</h2>
        <div class="font-serif text-base leading-relaxed text-ink dark:text-gray-200 space-y-3">
          <p>
            We believe that understanding the brain requires both experiment and theory, working
            in tight dialogue. Our lab develops mathematical frameworks — rooted in geometry,
            information theory, and statistical learning — that make quantitative, falsifiable
            predictions about neural circuit computation.
          </p>
          <p>
            These predictions are tested against large-scale neural recordings from behaving
            animals using Neuropixels electrophysiology and two-photon calcium imaging. When
            theory and data disagree, we revise our theories. This iterative process is how
            science advances.
          </p>
          <p>
            A second mission is to build bridges between neuroscience and AI. We believe that
            understanding biological intelligence can inspire more robust, efficient, and
            interpretable artificial systems — and vice versa.
          </p>
        </div>
      </div>
      <div>
        <h2 class="font-sans text-xl font-semibold text-ink dark:text-white mb-4">Values</h2>
        <div class="space-y-4">
          {values.map(v => (
            <div class="margin-rule pl-4">
              <h3 class="font-sans font-semibold text-ink dark:text-white">{v.title}</h3>
              <p class="font-serif text-sm text-ink-muted dark:text-gray-400 mt-0.5">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <section aria-labelledby="timeline-heading" class="mb-16">
      <h2 id="timeline-heading" class="section-heading mb-8">Lab Timeline</h2>
      <ol class="relative border-l border-gray-200 dark:border-gray-700 ml-4 space-y-0" role="list">
        {milestones.map((m, i) => (
          <li class="mb-8 ml-8 last:mb-0">
            <span class="absolute -left-4 flex items-center justify-center w-8 h-8 bg-accent text-white rounded-full text-xs font-bold ring-4 ring-paper dark:ring-ink">
              <span class="sr-only">Year: </span>{m.year.toString().slice(2)}
            </span>
            <div class:list={['card p-4', i === milestones.length - 1 ? 'border-accent/30' : '']}>
              <time class="font-mono text-xs font-bold text-accent mb-1 block">{m.year}</time>
              <p class="font-serif text-sm text-ink dark:text-gray-200 leading-relaxed">{m.event}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Funders / affiliations -->
    <section aria-labelledby="funders-heading">
      <h2 id="funders-heading" class="font-sans text-sm font-bold uppercase tracking-widest text-ink-faint mb-6 flex items-center gap-3">
        Funders & Affiliations
        <span class="flex-1 h-px bg-gray-100 dark:bg-gray-800"></span>
      </h2>
      <div class="flex flex-wrap gap-4">
        {['European Research Council', 'Agence Nationale de la Recherche', 'CNRS', 'Université de Somewhere', 'Human Brain Project'].map(org => (
          <div class="card px-4 py-3 text-sm font-medium text-ink-muted dark:text-gray-400">
            {org}
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
