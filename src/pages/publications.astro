---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { sortByYear, groupByYear } from '../lib/utils';

const allPubs = await getCollection('publications');
const sorted = sortByYear(allPubs);
const grouped = groupByYear(sorted);
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);

const allTypes = [...new Set(allPubs.map(p => p.data.type))].sort();
---

<BaseLayout title="Publications" description="Full list of publications from the DeLi Lab.">
  <div class="container-lab py-12">

    <!-- Page header -->
    <div class="mb-10 border-b border-rule pb-8">
      <h1 class="section-heading">Publications</h1>
      <p class="section-lead">Our research outputs, with open access where possible.</p>

      <!-- Toolbar -->
      <div class="flex flex-col sm:flex-row gap-3 mt-6" id="pub-toolbar">
        <!-- Search -->
        <div class="relative flex-1 max-w-sm">
          <label for="pub-search" class="sr-only">Search publications</label>
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-faint pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/>
          </svg>
          <input
            id="pub-search"
            type="search"
            placeholder="Search title, author…"
            class="w-full pl-8 pr-4 py-1.5 text-sm bg-surface border border-rule focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent"
            autocomplete="off"
          />
        </div>

        <!-- Type filter -->
        <div class="flex items-center gap-1.5 flex-wrap">
          <button class="pub-filter-btn text-xs font-medium px-2.5 py-1 border border-ink bg-ink text-paper" data-filter="type" data-value="all">All</button>
          {allTypes.map(t => (
            <button class="pub-filter-btn text-xs font-medium px-2.5 py-1 border border-rule text-ink-muted hover:border-ink hover:text-ink transition-colors" data-filter="type" data-value={t}>
              {t.charAt(0).toUpperCase() + t.slice(1)}
            </button>
          ))}
        </div>
      </div>

      <!-- Count -->
      <p class="mt-3 text-xs text-ink-faint" id="pub-count" aria-live="polite">
        <span id="pub-count-num">{allPubs.length}</span> publications
      </p>
    </div>

    <!-- Timeline -->
    <div id="pub-list-view" class="relative">
      <!-- Vertical rule -->
      <div class="hidden sm:block absolute left-20 top-0 bottom-0 w-px bg-rule" aria-hidden="true"></div>

      {years.map(year => (
        <section class="pub-year-group relative mb-12 sm:flex sm:gap-12" data-year={year} aria-labelledby={`year-${year}`}>
          <!-- Year label -->
          <div class="hidden sm:flex w-20 shrink-0 justify-end pt-0.5">
            <h2 id={`year-${year}`} class="relative z-10 text-sm font-semibold text-ink tabular-nums">
              {year}
            </h2>
          </div>
          <!-- Mobile year -->
          <h2 id={`year-${year}-mobile`} class="sm:hidden text-sm font-semibold text-ink mb-4">{year}</h2>

          <!-- Entries -->
          <div class="flex-1 space-y-8 sm:pl-0">
            {grouped[year].map(pub => {
              const { title, authors, venue, venueShort, type, doi, arxiv, pdf, abstract, keywords, featured, award } = pub.data;
              const doiUrl  = doi   ? `https://doi.org/${doi}`       : null;
              const arxivUrl = arxiv ? `https://arxiv.org/abs/${arxiv}` : null;
              const href    = doiUrl ?? arxivUrl ?? `/publications/${pub.id}`;
              const abstractId = `abstract-${pub.id}`;
              return (
                <article
                  class="pub-card group"
                  data-type={type}
                  data-title={title.toLowerCase()}
                  data-authors={authors.join(' ').toLowerCase()}
                  data-categories={(pub.data.categories ?? []).join(',')}
                >
                  <!-- Type + award badges -->
                  <div class="flex items-center gap-2 mb-1">
                    <span class="eyebrow">{type}</span>
                    {award && <span class="eyebrow text-amber-600">★ {award}</span>}
                    {featured && <span class="eyebrow text-accent">Featured</span>}
                  </div>

                  <!-- Title -->
                  <h3 class="font-sans text-[0.9375rem] font-semibold leading-snug text-ink group-hover:text-accent transition-colors duration-150">
                    <a href={href} target={doiUrl || arxivUrl ? '_blank' : '_self'} rel={doiUrl || arxivUrl ? 'noopener' : undefined}>
                      {title}
                    </a>
                  </h3>

                  <!-- Authors -->
                  <p class="mt-0.5 text-sm text-ink-muted">
                    {authors.join(', ')}
                  </p>

                  <!-- Venue -->
                  <p class="mt-0.5 text-sm">
                    <span class="italic text-ink-muted">{venueShort ?? venue}</span>
                    <span class="text-ink-faint mx-1">·</span>
                    <span class="text-ink-faint">{year}</span>
                  </p>

                  <!-- Keywords -->
                  {keywords && keywords.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1">
                      {keywords.map(kw => <span class="tag">{kw}</span>)}
                    </div>
                  )}

                  <!-- Actions -->
                  <div class="mt-2 flex flex-wrap items-center gap-3">
                    {doiUrl && (
                      <a href={doiUrl} target="_blank" rel="noopener" class="text-xs text-ink-faint hover:text-accent transition-colors">DOI ↗</a>
                    )}
                    {arxivUrl && (
                      <a href={arxivUrl} target="_blank" rel="noopener" class="text-xs text-ink-faint hover:text-accent transition-colors">arXiv ↗</a>
                    )}
                    {pdf && (
                      <a href={pdf} target="_blank" rel="noopener" class="text-xs text-ink-faint hover:text-accent transition-colors">PDF ↗</a>
                    )}
                    {abstract && (
                      <button
                        class="text-xs text-ink-faint hover:text-accent transition-colors abstract-toggle"
                        data-target={abstractId}
                        aria-expanded="false"
                      >
                        Abstract ↓
                      </button>
                    )}
                  </div>

                  <!-- Abstract (hidden by default) -->
                  {abstract && (
                    <p id={abstractId} class="pub-abstract hidden mt-3 text-sm text-ink-muted font-serif leading-relaxed border-l-2 border-rule pl-3">
                      {abstract}
                    </p>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>

    <!-- Empty state -->
    <div id="pub-empty" class="hidden text-center py-20 text-ink-faint">
      <p class="text-sm">No publications match your search.</p>
      <button id="clear-filters" class="mt-2 link text-xs">Clear filters</button>
    </div>

  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('pub-search') as HTMLInputElement;
  const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.pub-filter-btn');
  const emptyState  = document.getElementById('pub-empty')!;
  const countSpan   = document.getElementById('pub-count-num')!;
  const clearBtn    = document.getElementById('clear-filters')!;

  let currentType   = 'all';
  let currentSearch = '';

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>('.pub-card');
    let visible = 0;

    cards.forEach(card => {
      const typeMatch   = currentType === 'all' || card.dataset.type === currentType;
      const q           = currentSearch.toLowerCase();
      const searchMatch = !q || (card.dataset.title ?? '').includes(q) || (card.dataset.authors ?? '').includes(q);
      const show        = typeMatch && searchMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    // Hide empty year sections
    document.querySelectorAll<HTMLElement>('.pub-year-group').forEach(group => {
      const hasVisible = Array.from(group.querySelectorAll<HTMLElement>('.pub-card')).some(c => c.style.display !== 'none');
      group.style.display = hasVisible ? '' : 'none';
    });

    countSpan.textContent = String(visible);
    emptyState.classList.toggle('hidden', visible > 0);
  }

  searchInput.addEventListener('input', e => {
    currentSearch = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentType = btn.dataset.value!;
      filterBtns.forEach(b => {
        const active = b.dataset.value === currentType;
        b.classList.toggle('bg-ink',    active);
        b.classList.toggle('text-paper', active);
        b.classList.toggle('border-ink', active);
        b.classList.toggle('text-ink-muted', !active);
        b.classList.toggle('border-rule',    !active);
      });
      applyFilters();
    });
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    currentSearch = '';
    currentType = 'all';
    filterBtns.forEach(b => {
      const active = b.dataset.value === 'all';
      b.classList.toggle('bg-ink', active);
      b.classList.toggle('text-paper', active);
      b.classList.toggle('border-ink', active);
      b.classList.toggle('text-ink-muted', !active);
      b.classList.toggle('border-rule', !active);
    });
    applyFilters();
  });

  // Abstract toggles
  document.querySelectorAll<HTMLButtonElement>('.abstract-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target!);
      if (!target) return;
      const open = !target.classList.contains('hidden');
      target.classList.toggle('hidden', open);
      btn.textContent = open ? 'Abstract ↓' : 'Abstract ↑';
      btn.setAttribute('aria-expanded', String(!open));
    });
  });
</script>
