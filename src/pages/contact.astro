---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/config';
---

<BaseLayout title="Contact" description="Contact the Neural Computation Laboratory — location, email, and open positions.">
  <div class="container-lab py-12">
    <div class="mb-10 border-b border-gray-200 dark:border-gray-800 pb-8">
      <h1 class="section-heading">Contact</h1>
      <p class="section-lead max-w-2xl">We welcome enquiries from prospective students, collaborators, and the press.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <!-- Left: contact info -->
      <div class="space-y-8">
        <!-- Address block -->
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-4">Location</h2>
          <address class="not-italic space-y-1 font-serif text-base text-ink dark:text-gray-200">
            <p class="font-sans font-semibold text-ink dark:text-white not-italic">{SITE.name}</p>
            <p>{SITE.department}</p>
            <p>{SITE.institution}</p>
            <p>{SITE.address}</p>
          </address>
        </div>

        <!-- Email -->
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-4">Email</h2>
          <ul class="space-y-2 text-sm" role="list">
            <li>
              <span class="text-ink-faint">General enquiries:</span>{' '}
              <a href={`mailto:${SITE.email}`} class="link">{SITE.email}</a>
            </li>
            <li>
              <span class="text-ink-faint">PI (Prof. Vasquez):</span>{' '}
              <a href="mailto:elena.vasquez@university.edu" class="link">elena.vasquez@university.edu</a>
            </li>
          </ul>
        </div>

        <!-- Open positions -->
        <div class="card p-6 border-l-2 border-l-margin">
          <h2 class="font-sans font-semibold text-ink dark:text-white mb-3">Open Positions</h2>
          <div class="space-y-3">
            {[
              { role: '2 × PhD Students', detail: 'Fully funded, 4 years — starting Sept 2024', status: 'Open' },
              { role: '1 × Postdoctoral Researcher', detail: '2+1 years — starting flexible 2024', status: 'Open' },
              { role: 'M2 Internships', detail: '5–6 months, Spring 2025', status: 'Apply Oct–Nov' },
            ].map(pos => (
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-sans text-sm font-semibold text-ink dark:text-white">{pos.role}</p>
                  <p class="text-xs text-ink-faint">{pos.detail}</p>
                </div>
                <span class="flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400">
                  {pos.status}
                </span>
              </div>
            ))}
          </div>
          <p class="mt-4 font-serif text-sm text-ink-muted dark:text-gray-400">
            Send a CV and a brief statement of interest to{' '}
            <a href="mailto:elena.vasquez@university.edu" class="link">elena.vasquez@university.edu</a>.
            Subject line: <span class="font-mono">Application 2024 — [position]</span>.
          </p>
        </div>

        <!-- Social -->
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-4">Follow</h2>
          <div class="flex gap-4">
            <a href={`https://twitter.com/${SITE.twitter.replace('@','')}`} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-ink-muted hover:text-accent transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              {SITE.twitter}
            </a>
            <a href={SITE.github} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-ink-muted hover:text-accent transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
      </div>

      <!-- Right: map placeholder + getting there -->
      <div class="space-y-6">
        <!-- Map placeholder -->
        <div class="rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-800 h-64 flex items-center justify-center border border-gray-200 dark:border-gray-700">
          <div class="text-center text-ink-faint">
            <svg class="w-8 h-8 mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
            </svg>
            <p class="text-sm font-medium">42 Campus Boulevard</p>
            <p class="text-xs">75005 Paris, France</p>
            <a
              href="https://maps.google.com/?q=42+Campus+Boulevard+Paris"
              target="_blank"
              rel="noopener"
              class="inline-block mt-3 text-xs text-accent hover:underline"
            >
              Open in Google Maps →
            </a>
          </div>
        </div>

        <!-- Getting there -->
        <div class="card p-5">
          <h2 class="font-sans font-semibold text-ink dark:text-white mb-4">Getting Here</h2>
          <ul class="space-y-3 text-sm" role="list">
            {[
              { icon: '🚇', label: 'Métro', detail: 'Line 7 — Campus station (5 min walk)' },
              { icon: '🚌', label: 'Bus', detail: 'Lines 21, 27 — Campus stop' },
              { icon: '🚂', label: 'RER', detail: 'RER B — Denfert-Rochereau (15 min walk)' },
              { icon: '✈️', label: 'CDG Airport', detail: 'RER B direct, ~45 min' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="text-lg" aria-hidden="true">{item.icon}</span>
                <div>
                  <span class="font-sans font-medium text-ink dark:text-white">{item.label}: </span>
                  <span class="text-ink-muted dark:text-gray-400">{item.detail}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
