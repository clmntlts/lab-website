---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/config';
---

<BaseLayout title="Contact" description="Contact the DeLi Lab — location, email, and research participation.">
  <div class="container-lab py-12">
    <div class="mb-10 border-b border-rule pb-8">
      <h1 class="section-heading">Contact</h1>
      <p class="section-lead">We welcome enquiries from prospective students, collaborators, families, and the press.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Left: contact info -->
      <div class="space-y-8">

        <!-- Address -->
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-4">Location</h2>
          <address class="not-italic font-serif text-base text-ink space-y-0.5">
            <p class="font-sans font-semibold not-italic">{SITE.shortName} — {SITE.institution}</p>
            <p>{SITE.department}</p>
            <p>Place Cardinal Mercier 10, bte L3.05.01</p>
            <p>1348 Louvain-la-Neuve, Belgium</p>
          </address>
        </div>

        <!-- Email -->
        <div>
          <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-4">Email</h2>
          <ul class="space-y-2 text-sm" role="list">
            <li>
              <span class="text-ink-faint">General enquiries: </span>
              <a href={`mailto:${SITE.email}`} class="link">{SITE.email}</a>
            </li>
            <li>
              <span class="text-ink-faint">Prof. Marie Van Reybroeck: </span>
              <a href="mailto:marie.vanreybroeck@uclouvain.be" class="link">marie.vanreybroeck@uclouvain.be</a>
            </li>
          </ul>
        </div>

        <!-- Participate -->
        <div class="card p-6" style="border-left: 2px solid var(--color-accent);">
          <h2 class="font-sans font-semibold text-ink mb-2">Participate in Our Research</h2>
          <p class="font-serif text-sm text-ink-muted leading-relaxed mb-4">
            We regularly recruit children and adults for studies on reading, spelling, and handwriting.
            Participation is free, voluntary, and takes place at UCLouvain in Louvain-la-Neuve.
            Two ongoing studies are currently open:
          </p>
          <ul class="space-y-2 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">→</span>
              <span><span class="font-medium">GraphoMot</span> — graphomotor development in children</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">→</span>
              <span><span class="font-medium">PhonoDéno</span> — phonological awareness and rapid naming</span>
            </li>
          </ul>
          <p class="mt-4 font-serif text-sm text-ink-muted">
            Interested? Contact us at <a href={`mailto:${SITE.email}`} class="link">{SITE.email}</a>.
          </p>
        </div>

      </div>

      <!-- Right: map -->
      <div class="space-y-6">
        <div class="overflow-hidden border border-rule h-72">
          <iframe
            title="DeLi Lab location — Place Cardinal Mercier 10, Louvain-la-Neuve"
            src="https://www.openstreetmap.org/export/embed.html?bbox=4.6095%2C50.6675%2C4.6195%2C50.6725&layer=mapnik&marker=50.670%2C4.6145"
            width="100%"
            height="100%"
            loading="lazy"
            style="border: 0;"
          ></iframe>
        </div>
        <p class="text-xs text-ink-faint text-right">
          <a href="https://www.openstreetmap.org/?mlat=50.670&mlon=4.6145#map=17/50.670/4.6145" target="_blank" rel="noopener" class="hover:text-accent transition-colors">
            Open in OpenStreetMap →
          </a>
        </p>

        <!-- Getting there -->
        <div class="card p-5">
          <h2 class="font-sans font-semibold text-ink mb-4">Getting Here</h2>
          <ul class="space-y-3 text-sm" role="list">
            {[
              { label: 'Train', detail: 'Ottignies station, then bus 11 to Louvain-la-Neuve' },
              { label: 'Bus', detail: 'TEC line 11 from Ottignies or 57 from Wavre' },
              { label: 'Car', detail: 'Exit 9 (Louvain-la-Neuve) on the E411 motorway — free parking on campus' },
              { label: 'From Brussels', detail: 'Train to Ottignies (~30 min), then bus (~10 min)' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="font-sans font-medium text-ink w-16 shrink-0">{item.label}</span>
                <span class="text-ink-muted">{item.detail}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
