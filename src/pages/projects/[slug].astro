---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.id }, props: { project: p } }));
}

interface Props { project: CollectionEntry<'projects'>; }
const { project } = Astro.props;
const { Content } = await render(project);
const { title, subtitle, status, startYear, endYear, tags, funders, members } = project.data;

const allTeam = await getCollection('team');
const projectMembers = allTeam.filter(m => members.includes(m.id));
---

<BaseLayout title={title} description={subtitle ?? title}>
  <div class="container-lab py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <a href="/projects" class="text-sm text-ink-faint hover:text-accent transition-colors flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        All projects
      </a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <div class="mb-6">
          <span class:list={[
            'inline-flex items-center px-2 py-0.5 rounded text-xs font-medium mb-3',
            status === 'active' ? 'bg-green-50 text-green-700' : 'bg-gray-50 text-gray-600'
          ]}>{status}</span>
          <h1 class="font-sans text-3xl font-semibold text-ink">{title}</h1>
          {subtitle && <p class="font-serif italic text-ink-muted mt-2 text-lg">{subtitle}</p>}
        </div>

        <div class="prose prose-base max-w-none font-serif">
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Details -->
        <div class="card p-5 space-y-4">
          <div>
            <p class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-1">Duration</p>
            <p class="text-sm font-medium">{startYear}{endYear ? `–${endYear}` : '–present'}</p>
          </div>
          {funders.length > 0 && (
            <div>
              <p class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-1">Funded by</p>
              <ul class="text-sm space-y-1" role="list">
                {funders.map(f => <li>{f}</li>)}
              </ul>
            </div>
          )}
          {tags.length > 0 && (
            <div>
              <p class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-2">Topics</p>
              <div class="flex flex-wrap gap-1.5">
                {tags.map(t => <span class="tag text-xs">{t}</span>)}
              </div>
            </div>
          )}
        </div>

        <!-- Members -->
        {projectMembers.length > 0 && (
          <div class="card p-5">
            <h2 class="font-sans text-xs font-bold uppercase tracking-widest text-ink-faint mb-3">Team</h2>
            <ul class="space-y-3" role="list">
              {projectMembers.map(m => (
                <li class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full overflow-hidden bg-gray-100 flex-shrink-0">
                    {m.data.photo ? (
                      <img src={m.data.photo} alt={m.data.name} class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-xs font-bold text-gray-400">{m.data.name.charAt(0)}</div>
                    )}
                  </div>
                  <div>
                    <a href={`/team/${m.id}`} class="text-sm font-medium text-ink hover:text-accent transition-colors">{m.data.name}</a>
                    <p class="text-xs text-ink-faint">{m.data.role}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
