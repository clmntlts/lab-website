---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

const active = sorted.filter(p => p.data.status === 'active');
const completed = sorted.filter(p => p.data.status === 'completed');

const statusColors = {
  active: 'bg-green-50 text-green-700',
  completed: 'bg-gray-50 text-gray-600',
  planned: 'bg-blue-50 text-blue-700',
};
---

<BaseLayout title="Projects" description="Research projects of the Neural Computation Laboratory.">
  <div class="container-lab py-12">
    <div class="mb-10 border-b border-gray-200 pb-8">
      <h1 class="section-heading">Projects</h1>
      <p class="section-lead max-w-2xl">Our funded research programmes and collaborative projects.</p>
    </div>

    <!-- Active projects -->
    {active.length > 0 && (
      <section aria-labelledby="active-heading" class="mb-14">
        <h2 id="active-heading" class="font-sans text-sm font-bold uppercase tracking-widest text-ink-faint mb-6 flex items-center gap-3">
          Active Projects
          <span class="flex-1 h-px bg-gray-100"></span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {active.map((project) => (
              <article class="card p-6 flex flex-col gap-4 border-l-2 border-l-accent">
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <h3 class="font-sans text-lg font-semibold text-ink leading-snug">
                      <a href={`/projects/${project.id}`} class="hover:text-accent transition-colors">{project.data.title}</a>
                    </h3>
                    {project.data.subtitle && (
                      <p class="text-sm text-ink-muted mt-0.5 font-serif italic">{project.data.subtitle}</p>
                    )}
                  </div>
                  <span class:list={['flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium', statusColors[project.data.status]]}>
                    {project.data.status}
                  </span>
                </div>

                {project.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {project.data.tags.map(tag => <span class="tag text-xs">{tag}</span>)}
                  </div>
                )}

                {project.data.funders.length > 0 && (
                  <div class="text-xs text-ink-faint">
                    Funded by: {project.data.funders.join(', ')}
                  </div>
                )}

                <a href={`/projects/${project.id}`} class="link text-sm mt-auto">Read more &rarr;</a>
              </article>
          ))}
        </div>
      </section>
    )}

    <!-- Completed projects -->
    {completed.length > 0 && (
      <section aria-labelledby="completed-heading">
        <h2 id="completed-heading" class="font-sans text-sm font-bold uppercase tracking-widest text-ink-faint mb-6 flex items-center gap-3">
          Completed Projects
          <span class="flex-1 h-px bg-gray-100"></span>
        </h2>
        <div class="space-y-4">
          {completed.map(project => (
            <article class="card p-5 flex items-center justify-between gap-4">
              <div>
                <h3 class="font-sans font-semibold text-ink">
                  <a href={`/projects/${project.id}`} class="hover:text-accent transition-colors">{project.data.title}</a>
                </h3>
                <p class="text-sm text-ink-muted">
                  {project.data.startYear}
                  {project.data.endYear ? `â€"${project.data.endYear}` : 'â€"present'}
                  {project.data.funders.length > 0 && ` Â· ${project.data.funders.join(', ')}`}
                </p>
              </div>
              <span class:list={['flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium', statusColors.completed]}>
                completed
              </span>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
