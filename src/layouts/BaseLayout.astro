---
import { SITE } from '../lib/config';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';
import BackToTop from '../components/ui/BackToTop.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  class?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  noIndex = false,
  class: className,
} = Astro.props;

const pageTitle = title ? `${title} â€” ${SITE.shortName}` : `${SITE.name}`;
const canonicalURL = new URL(Astro.url.pathname, SITE.url);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, SITE.url)} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, SITE.url)} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ResearchOrganization",
      "name": SITE.name,
      "url": SITE.url,
      "description": SITE.description,
      "address": SITE.address,
      "parentOrganization": {
        "@type": "CollegeOrUniversity",
        "name": SITE.institution
      }
    })} />

    <title>{pageTitle}</title>
  </head>

  <body class="flex flex-col min-h-screen bg-paper text-ink">
    <!-- Skip navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Navigation />

    <main id="main-content" class:list={['flex-1', className]} tabindex="-1" data-pagefind-body>
      <slot />
    </main>

    <Footer />

    <BackToTop />

  </body>
</html>
